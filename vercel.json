{
  "version": 2,

  "routes": [
    {
      "src": "^/api/update/([^/]+)/([^/]+)/([^/]+)$",
      "dest": "/api/update?platform=$1&quality=$2&commit=$3"
    },
    {
      "src": "^/api/download/([^/]+)/([^/]+)$",
      "dest": "/api/download/$1/$2"
    },

    {
      "handle": "filesystem"
    },

    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}